ed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "bead9b22-9483-41aa-b47c-4bc31f806ec9", "node_type": "4", "metadata": {}, "hash": "c868896ee96a2719f560aba5819fe6be8fc0a0e2d98fd5e0702296d42e1d20bb", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "**CRITICAL DUCKDB DATE RULE 1:** \u8fc7\u6ee4\u5e74\u4efd\u4f7f\u7528 `year(Date) = 2025` \u6216 `date_part('year', Date) = 2025`\u3002", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 95, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "f35f011e-09b0-4dbd-a38d-0c08c4503e2c": {"__data__": {"id_": "f35f011e-09b0-4dbd-a38d-0c08c4503e2c", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "7e4923c6-bf58-4b7c-82e7-9c4d6561080f", "node_type": "4", "metadata": {}, "hash": "23577405b80a9b25a2646d04d807e9c4bf38c740d542c2380683d48766eb777c", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "**CRITICAL DUCKDB DATE RULE 2:** \u8fc7\u6ee4\u6708\u4efd\u4f7f\u7528 `month(Date) = 10` \u6216 `date_part('month', Date) = 10`\u3002", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 93, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "d5be8f05-f3fa-4539-9c15-b9ae35f78ad8": {"__data__": {"id_": "d5be8f05-f3fa-4539-9c15-b9ae35f78ad8", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "1feb536f-47b4-491d-8172-2363fedd15a0", "node_type": "4", "metadata": {}, "hash": "6535b1d0031a8cfc5eda5020ce5805c6f218701f0583cf800becfe3bb6de8d45", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "**CRITICAL DUCKDB TIMESTAMP:** DuckDB \u5904\u7406\u5b57\u7b26\u4e32\u65e5\u671f\u975e\u5e38\u667a\u80fd\uff0c\u76f4\u63a5\u4f7f\u7528 `'2025-01-01'` \u5373\u53ef\uff0c\u4e0d\u9700\u8981\u50cf Postgres \u90a3\u6837\u52a0 `::timestamp`\u3002", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 105, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "763f3470-de65-442c-b55a-11fa4517ba73": {"__data__": {"id_": "763f3470-de65-442c-b55a-11fa4517ba73", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "0143c886-fdd0-404e-9135-c74961bdbcd9", "node_type": "4", "metadata": {}, "hash": "6afb7759496aab5acc589fd71b06fe0c579b019ca5730a48267fd34b7dfeecd5", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "**ABSOLUTE CRITICAL RULE (\u6708\u672b\u5bf9\u9f50):** \u8054\u63a5\u4e24\u8868\u53d6\u6708\u5ea6\u6536\u76d8\u4ef7\u65f6\uff0c\u5fc5\u987b\u589e\u52a0\u8fc7\u6ee4\u6761\u4ef6\uff1a`T1.Date = (SELECT MAX(sd_sub.Date) FROM stock_data sd_sub WHERE sd_sub.Ticker = T1.Ticker AND date_trunc('month', sd_sub.Date) = date_trunc('month', T1.Date))`\u3002", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 217, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "d5a0e764-c627-41da-9d85-28efb6a29e42": {"__data__": {"id_": "d5a0e764-c627-41da-9d85-28efb6a29e42", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "4405f380-dc9b-4b52-be22-888497785b87", "node_type": "4", "metadata": {}, "hash": "523e69814279e6332aedd61e2d869b9d14973279f9084fadac77b2f56e3cfc0b", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "**Top N \u89c4\u5219:** \u83b7\u53d6\u6700\u5927\u503c\u6216\u6392\u540d\u65f6\uff0c\u4f7f\u7528 `ORDER BY [\u5b57\u6bb5] DESC LIMIT N`\u3002", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 56, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "c3d81779-2659-476c-acd8-037a881292b4": {"__data__": {"id_": "c3d81779-2659-476c-acd8-037a881292b4", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "8156288c-711f-4ab8-b541-3f8ca3010599", "node_type": "4", "metadata": {}, "hash": "6bf7dbd7a3e4d62e8584f09096eef28e38be24a396b653e39bce50bbbead8205", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "**CRITICAL EXAMPLE (DuckDB \u6a21\u677f):** \u67e5\u8be2 'PARA' 2025\u5e74\u6bcf\u6708\u6536\u76d8\u4ef7\u53ca\u6da8\u5e45\uff1a`SELECT T1.Ticker, T1.Date, T1.Close, T2.Monthly_Change_Pct FROM stock_data AS T1 JOIN stock_monthly_change AS T2 ON T1.Ticker = T2.Ticker AND date_trunc('month', T1.Date) = date_trunc('month', T2.Month_Start_Date) WHERE T1.Ticker = 'PARA' AND year(T1.Date) = 2025 AND T1.Date = (SELECT MAX(Date) FROM stock_data sd_sub WHERE sd_sub.Ticker = T1.Ticker AND date_trunc('month', sd_sub.Date) = date_trunc('month', T1.Date)) ORDER BY T1.Date`\u3002", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 497, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}}}